#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * ADP — standalone console entry point.
 *
 * Registers the ADP console commands that do not need framework DI:
 *   - serve               — standalone HTTP server (panel + API)
 *   - frontend:update     — download latest panel build from GitHub Release
 *   - debug:fixtures      — from app-dev-panel/testing, when installed
 *
 * Commands that rely on live collector/storage wiring (debug:query, debug:reset,
 * debug:tail, dev, etc.) are exposed via the per-framework adapters' own CLI
 * integrations.
 *
 * Usage:
 *   php vendor/bin/adp serve
 *   php vendor/bin/adp frontend:update check
 *   php vendor/bin/adp debug:fixtures http://localhost:8080
 */

// Find autoloader. `$GLOBALS['_composer_autoload_path']` is set by the Composer-generated
// bin proxy (vendor/bin/adp) and points at vendor/autoload.php directly — prefer it when
// available so we don't have to juggle relative paths across install layouts.
$autoloaded = false;
if (isset($GLOBALS['_composer_autoload_path']) && file_exists((string) $GLOBALS['_composer_autoload_path'])) {
    require (string) $GLOBALS['_composer_autoload_path'];
    $autoloaded = true;
} else {
    $autoloadPaths = [
        __DIR__ . '/../../../autoload.php',          // Composer install: vendor/app-dev-panel/cli/bin/ → vendor/autoload.php
        __DIR__ . '/../../../vendor/autoload.php',   // Monorepo: libs/Cli/bin/ → vendor/autoload.php
        __DIR__ . '/../vendor/autoload.php',         // Standalone checkout with its own vendor/
    ];
    foreach ($autoloadPaths as $autoloadPath) {
        if (!file_exists($autoloadPath)) {
            continue;
        }
        require $autoloadPath;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Autoloader not found. Run composer install.\n");
    exit(1);
}

$application = new Symfony\Component\Console\Application('adp', '1.x-dev');

// Symfony Console renamed Application::add() → Application::addCommand() in 8.0. Support both
// 7.x and 8.x so the binary works on the full range declared in composer.json (^6 | ^7 | ^8).
$addCommand = static function (Symfony\Component\Console\Application $app, Symfony\Component\Console\Command\Command $command): void {
    if (method_exists($app, 'addCommand')) {
        $app->addCommand($command);
    } else {
        $app->add($command);
    }
};

$addCommand($application, new AppDevPanel\Cli\Command\ServeCommand());
$addCommand($application, new AppDevPanel\Cli\Command\FrontendUpdateCommand());

// Register DebugFixturesCommand when app-dev-panel/testing is present.
// The Testing package is not a required dependency of libs/Cli (enforced by modulite),
// so we resolve it via FQCN at runtime rather than a `use` statement.
$fixturesCommandClass = 'AppDevPanel\\Testing\\Command\\DebugFixturesCommand';
if (class_exists($fixturesCommandClass)) {
    /** @var Symfony\Component\Console\Command\Command $command */
    $command = new $fixturesCommandClass();
    $addCommand($application, $command);
}

exit($application->run());
